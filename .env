APP_ENV=production
APP_KEY=${APP_KEY}
APP_DEBUG=false
APP_URL=https://ton-projet.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données (Railway injecte les valeurs)
DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_DATABASE=${DB_NAME}
DB_USERNAME=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# Cache & sessions
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
